# Copy this file to .env.kis and fill in your own values.
# Do not wrap values in quotes. Keep one KEY=VALUE per line.

# MCP server settings
ENV=live
MCP_TYPE=sse
MCP_HOST=0.0.0.0
MCP_PORT=3000
MCP_PATH=/sse

# KIS real trading credentials
KIS_APP_KEY=
KIS_APP_SECRET=

# KIS paper trading credentials
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=

# Account settings
KIS_HTS_ID=
KIS_ACCT_STOCK=
KIS_ACCT_FUTURE=
KIS_PAPER_STOCK=
KIS_PAPER_FUTURE=
KIS_PROD_TYPE=01

# Optional custom endpoints. Leave blank unless KIS tells you to override them.
KIS_URL_REST=
KIS_URL_REST_PAPER=
KIS_URL_WS=
KIS_URL_WS_PAPER=
